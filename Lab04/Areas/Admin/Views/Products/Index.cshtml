@model IEnumerable<Product>
@{
    var vi = new System.Globalization.CultureInfo("vi-VN");
}

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">Danh sách sản phẩm</h3>
    </div>
    <div class="card-body">
        <a asp-action="Create" class="btn btn-primary mb-3"><i class="bi bi-plus-lg me-1"></i>Thêm sản phẩm</a>
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th style="width:60px">#</th>
                    <th style="width:90px">Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá</th>
                    <th>Mới?</th>
                    <th style="width:160px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int stt = 1;
                    foreach (var product in Model)
                    {
                        <tr>
                            <td>@(stt++)</td>
                            <td><img src="~/img/@product.ImagePath" style="width:60px;height:60px;object-fit:cover;" /></td>
                            <td>@product.ProductName</td>
                            <td>@product.Category?.CategoryName</td>
                            <td>@product.Price.ToString("N0", vi) đ</td>
                            <td>
                                @if (product.IsNew)
                                {
                                    <span class="badge text-bg-success">Mới</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@product.ProductId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pen"></i></a>
                                <form asp-action="Delete" asp-route-id="@product.ProductId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Chưa có sản phẩm nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
