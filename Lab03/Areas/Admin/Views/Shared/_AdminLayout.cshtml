<!doctype html>
<html lang="vi">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - Spicy Korea Admin" : "Spicy Korea Admin")</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />

    <!-- Fonts -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fontsource/source-sans-3@5.0.12/index.css" crossorigin="anonymous" media="print" onload="this.media = 'all'" />

    <!-- OverlayScrollbars -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css" crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" crossorigin="anonymous" />

    <!-- AdminLTE -->
    <link rel="stylesheet" href="~/admin/dist/css/adminlte.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <!-- Header -->
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                    <li class="nav-item d-none d-md-block">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link" target="_blank">Xem trang chủ</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-lte-toggle="fullscreen">
                            <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                            <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
                        </a>
                    </li>
                    <li class="nav-item dropdown user-menu">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <img src="~/admin/dist/assets/img/user2-160x160.jpg" class="user-image rounded-circle shadow" alt="User Image" />
                            <span class="d-none d-md-inline">@ViewBag.CurrentUsername</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                            <li class="user-header text-bg-primary">
                                <img src="~/admin/dist/assets/img/user2-160x160.jpg" class="rounded-circle shadow" alt="User Image" />
                                <p>@ViewBag.CurrentUsername<small>Quản trị viên Spicy Korea</small></p>
                            </li>
                            <li class="user-footer">
                                <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger float-end">Đăng xuất</a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </nav>
        <!-- /Header -->

        <!-- Sidebar -->
        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
            <div class="sidebar-brand">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="brand-link">
                    <span class="brand-text fw-bold">S<span class="text-primary">picy</span> Korea Admin</span>
                </a>
            </div>
            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu">
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Dashboard" ? "active" : "")">
                                <i class="nav-icon bi bi-house-heart-fill"></i>
                                <p>Trang chủ Admin</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Categories" ? "active" : "")">
                                <i class="nav-icon bi bi-tags-fill"></i>
                                <p>Danh mục</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Products" ? "active" : "")">
                                <i class="nav-icon bi bi-box-seam-fill"></i>
                                <p>Sản phẩm</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Blogs" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Blogs" ? "active" : "")">
                                <i class="nav-icon bi bi-newspaper"></i>
                                <p>Tin tức</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Orders" ? "active" : "")">
                                <i class="nav-icon bi bi-cart-check-fill"></i>
                                <p>Đơn hàng</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Users" ? "active" : "")">
                                <i class="nav-icon bi bi-people-fill"></i>
                                <p>Tài khoản</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Feedbacks" asp-action="Index" class="nav-link @(ViewData["ActiveMenu"] as string == "Feedbacks" ? "active" : "")">
                                <i class="nav-icon bi bi-chat-left-text-fill"></i>
                                <p>Liên hệ / Phản hồi</p>
                            </a>
                        </li>
                        <li class="nav-item">                       
                            <a asp-area="" asp-controller="Account" asp-action="Logout" class="nav-link text-danger @(ViewData["ActiveMenu"] as string == "Logout" ? "active" : "")"
                               onclick="return confirm('Bạn có chắc chắn muốn đăng xuất?')">
                                <i class="nav-icon bi bi-box-arrow-right"></i>
                                <p>Đăng xuất</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>
        <!-- /Sidebar -->

        <!-- App Main -->
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0">@ViewData["Title"]</h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Trang chủ</a></li>
                                <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible">
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible">
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            @TempData["Error"]
                        </div>
                    }
                    @RenderBody()
                </div>
            </div>
        </main>
        <!-- /App Main -->

        <footer class="app-footer">
            <strong>Bản quyền &copy; 2026 <a href="#" class="text-decoration-none">Spicy Korea</a>.</strong> Đồ án môn học - ASP.NET Core MVC.
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>
    <script src="~/admin/dist/js/adminlte.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
