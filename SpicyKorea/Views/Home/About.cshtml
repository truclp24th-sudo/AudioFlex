@{
    ViewData["Title"] = "Giới thiệu";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Giới Thiệu</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">Giới thiệu</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<!-- About Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="about-img position-relative overflow-hidden p-5 pe-0">
                    <img class="img-fluid w-100" src="~/img/picture.jpg">
                </div>
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <h1 class="display-5 mb-4">Khám Phá Hương Vị Mì Cay Đích Thực</h1>
                <p class="mb-4">Trải nghiệm hương vị cay nồng đặc trưng của mì cay Hàn Quốc. Sợi mì dai ngon kết hợp hoàn hảo cùng nước dùng đậm đà, được nêm nếm theo công thức gia truyền.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Sợi mì dai và tươi ngon tự nhiên.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Hương vị cay nồng, đậm đà từ các loại ớt tự nhiên.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Nước dùng được hầm kỹ, mang đến trải nghiệm tuyệt vời.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill py-3 px-5 mt-3">Xem chi tiết</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Firm Visit Start -->
<div class="container-fluid bg-primary bg-icon mt-5 py-6">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-md-7 wow fadeIn" data-wow-delay="0.1s">
                <h1 class="display-5 text-white mb-3">Khám phá hương vị</h1>
                <p class="text-white mb-0">Đánh thức mọi giác quan với sự kết hợp tinh tế giữa hải sản tươi và nước dùng 7 cấp độ cay nồng đặc trưng. Hãy đến và cùng chúng tôi khám phá hương vị mì cay đích thực, dai ngon đến sợi cuối cùng!</p>
            </div>
            <div class="col-md-5 text-md-end wow fadeIn" data-wow-delay="0.5s">
                <a asp-controller="Contact" asp-action="Index" class="btn btn-lg btn-secondary rounded-pill py-3 px-5">Truy cập ngay</a>
            </div>
        </div>
    </div>
</div>
<!-- Firm Visit End -->

<!-- Feature Start -->
<div class="container-fluid bg-light bg-icon py-6">
    <div class="container">
        <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <h1 class="display-5 mb-3">Đặc Điểm Nổi Bật</h1>
            <p>Khám phá hương vị mì cay đích thực với công thức nước dùng độc quyền, nguyên liệu tươi ngon và thử thách 7 cấp độ đầy kịch tính.</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="bg-white text-center h-100 p-4 p-xl-5">
                    <img class="img-fluid mb-4" src="~/img/icon 1.png" alt="">
                    <h4 class="mb-3">Nước Dùng Đậm Đà</h4>
                    <p class="mb-4">Kết hợp cùng gia vị chuẩn Hàn, mang lại vị ngọt thanh bùng nổ trong từng muỗng nước dùng.</p>
                    <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="bg-white text-center h-100 p-4 p-xl-5">
                    <img class="img-fluid mb-4" src="~/img/iconn 2.png" alt="">
                    <h4 class="mb-3">7 Cấp Độ Thử Thách</h4>
                    <p class="mb-4">Từ vị cay nhẹ nhàng đến siêu cay bùng cháy, chúng tôi mang đến hành trình chinh phục vị giác cho mọi tín đồ ăn cay.</p>
                    <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="bg-white text-center h-100 p-4 p-xl-5">
                    <img class="img-fluid mb-4" src="~/img/icon 3.png" alt="">
                    <h4 class="mb-3">Nguyên Liệu Tươi Sạch</h4>
                    <p class="mb-4">Hải sản tươi rói, thịt bò hảo hạng cùng rau củ xanh mát được lựa chọn kỹ lưỡng mỗi ngày để đảm bảo chất lượng tốt nhất.</p>
                    <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Feature End -->
