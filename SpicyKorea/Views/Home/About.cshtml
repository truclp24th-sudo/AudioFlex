@{
    ViewData["Title"] = "Giới thiệu";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Giới Thiệu</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">Giới thiệu</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<!-- About Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="about-img position-relative overflow-hidden p-5 pe-0">
                    <img class="img-fluid w-100" src="~/img/sound_2.jpg">
                </div>
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <h1 class="display-5 mb-4">Chạm Vào Sự Tĩnh Lặng, Thăng Hoa Cùng Âm Nhạc</h1>
                <p class="mb-4">Dừng lại giữa thế giới ồn ào và đắm mình vào không gian âm thanh tách biệt hoàn toàn. Chiếc tai nghe chụp tai này không chỉ là thiết bị, mà là chìa khóa mở ra thế giới cảm xúc riêng biệt, nơi từng nốt nhạc được tái tạo tinh tế và nguyên bản nhất.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Thiết kế ôm trọn hoàn hảo, tạo cảm giác nhẹ tênh như không đeo.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Công nghệ triệt tiêu tiếng ồn chủ động, trả lại không gian tĩnh lặng tuyệt đối.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Âm thanh đa tầng sâu lắng, nâng tầm trải nghiệm nghe lên chuẩn phòng thu.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill py-3 px-5 mt-3">Xem chi tiết</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Firm Visit Start -->
<div class="container-fluid bg-primary bg-icon mt-5 py-6">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-md-7 wow fadeIn" data-wow-delay="0.1s">
                <h1 class="display-5 text-white mb-3">Kiến tạo không gian âm thanh tuyệt đối</h1>
                <p class="text-white mb-0">Đánh thức mọi giác quan với sự kết hợp hoàn hảo giữa công nghệ âm thanh vòm đỉnh cao và thiết kế công thái học ôm trọn cảm xúc. Hãy để bản thân thăng hoa trong từng nốt nhạc, trải nghiệm chất âm chân thực đến từng nhịp thở!</p>
            </div>
            <div class="col-md-5 text-md-end wow fadeIn" data-wow-delay="0.5s">
                <a asp-controller="Contact" asp-action="Index" class="btn btn-lg btn-secondary rounded-pill py-3 px-5">Truy cập ngay</a>
            </div>
        </div>
    </div>
</div>
<!-- Firm Visit End -->

<!-- Feature Start -->
<div class="container-fluid bg-light bg-icon py-6">
    <div class="container">
        <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <h1 class="display-5 mb-3">Tinh Hoa Công Nghệ Âm Thanh</h1>
            <p>Khám phá sự hoàn mỹ trong từng giai điệu với thiết kế đỉnh cao, chất âm nguyên bản và công nghệ chống ồn đột phá.</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="bg-white text-center h-100 p-4 p-xl-5">
                    <img class="img-fluid mb-4" src="~/img/sound_3.jpg" alt="">
                    <h4 class="mb-3">Âm Thanh Hi-Fi Sống Động</h4>
                    <p class="mb-4">Thưởng thức chất âm chi tiết với âm bass mạnh mẽ, âm trung rõ nét và âm cao trong trẻo, mang đến trải nghiệm nghe nhạc chân thực.</p>
                    <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="bg-white text-center h-100 p-4 p-xl-5">
                    <img class="img-fluid mb-4" src="~/img/sound_4.jpg" alt="">
                    <h4 class="mb-3">Chống Ồn Hiệu Quả</h4>
                    <p class="mb-4">Khả năng chống ồn chủ động (ANC) đỉnh cao biến mọi không gian ồn ào trở thành sân khấu riêng, nơi chỉ còn bạn và những giai điệu yêu thích.</p>
                    <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="bg-white text-center h-100 p-4 p-xl-5">
                    <img class="img-fluid mb-4" src="~/img/sound_8.jpg" alt="">
                    <h4 class="mb-3">Thiết Kế Sang Trọng</h4>
                    <p class="mb-4">Khung tai nghe chắc chắn, đệm tai cao cấp và trọng lượng nhẹ, phù hợp cho học tập, làm việc và giải trí hàng ngày.</p>
                    <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Feature End -->
