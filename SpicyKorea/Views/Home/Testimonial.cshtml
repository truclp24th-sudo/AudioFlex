@{
    ViewData["Title"] = "Đánh giá";
}

<!-- Page Header Start -->
<div class="container-fluid page-header wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Đánh Giá</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">Đánh giá</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<!-- Testimonial Start -->
<div class="container-fluid bg-light bg-icon py-6">
    <div class="container">
        <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <h1 class="display-5 mb-3">Đánh Giá Của Khách Hàng</h1>
            <p>Mỗi đánh giá là một động lực để chúng tôi hoàn thiện hơn mỗi ngày. Cảm ơn các bạn đã luôn ủng hộ và dành tình cảm đặc biệt cho quán!</p>
        </div>
        <div class="owl-carousel testimonial-carousel wow fadeInUp" data-wow-delay="0.1s">
            <div class="testimonial-item position-relative bg-white p-5 mt-4">
                <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                <p class="mb-4">Nước dùng mì ở đây đậm đà thực sự, vị cay nồng của mì kết hợp với ly trà sữa béo ngậy giúp cân bằng vị giác hoàn hảo. Topping bò và hải sản đều rất tươi, sợi mì dai đúng chuẩn Hàn Quốc.</p>
                <div class="d-flex align-items-center">
                    <img class="flex-shrink-0 rounded-circle" src="~/img/anh 1.jpg" alt="">
                    <div class="ms-3">
                        <h5 class="mb-1">Lưu Học Nghĩa</h5>
                        <span>Diễn viên</span>
                    </div>
                </div>
            </div>
            <div class="testimonial-item position-relative bg-white p-5 mt-4">
                <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                <p class="mb-4">Mì cay hải sản ở đây là chân ái! Kim chi ăn kèm giòn, chua ngọt rất ưa miệng. Không gian quán thoáng mát, nhân viên phục vụ cực kỳ nhanh nhẹn dù quán rất đông khách.</p>
                <div class="d-flex align-items-center">
                    <img class="flex-shrink-0 rounded-circle" src="~/img/anh 2.jpg" alt="">
                    <div class="ms-3">
                        <h5 class="mb-1">Tiêu Chiến</h5>
                        <span>Diễn viên / Ca sĩ</span>
                    </div>
                </div>
            </div>
            <div class="testimonial-item position-relative bg-white p-5 mt-4">
                <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                <p class="mb-4">Lần đầu tôi thử thách với mì cay cấp độ 7 và thực sự là một trải nghiệm bùng nổ vị giác! Rất đáng để thử nếu bạn là một tín đồ ăn cay thứ thiệt. Sẽ còn quay lại ủng hộ quán nhiều lần.</p>
                <div class="d-flex align-items-center">
                    <img class="flex-shrink-0 rounded-circle" src="~/img/anh 3.jpg" alt="">
                    <div class="ms-3">
                        <h5 class="mb-1">Vương Nhất Bác</h5>
                        <span>Ca sĩ / MC</span>
                    </div>
                </div>
            </div>
            <div class="testimonial-item position-relative bg-white p-5 mt-4">
                <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                <p class="mb-4">Tôi hay đặt về nhà, dù giao hàng đi xa nhưng sợi mì vẫn giữ được độ dai, nước dùng đóng gói rất cẩn thận và vẫn còn nóng hổi. Rất hài lòng về cách đóng gói của quán.</p>
                <div class="d-flex align-items-center">
                    <img class="flex-shrink-0 rounded-circle" src="~/img/anh 4.jpg" alt="">
                    <div class="ms-3">
                        <h5 class="mb-1">Thành Nghị</h5>
                        <span>Diễn viên</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Testimonial End -->
