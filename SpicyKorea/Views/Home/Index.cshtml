@model IEnumerable<Product>
    @{
    ViewData["Title"] = "Trang chủ";
    var latestBlogs = ViewBag.LatestBlogs as IEnumerable<Blog>;
    var vi = new System.Globalization.CultureInfo("vi-VN");
    }

    <!-- Carousel Start -->
    <div class="container-fluid p-0 mb-5 wow fadeIn" data-wow-delay="0.1s">
        <div id="header-carousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img class="w-100" src="~/img/anh.jpg" alt="Image">
                    <div class="carousel-caption">
                        <div class="container">
                            <div class="row justify-content-start">
                                <div class="col-lg-7">
                                    <h1 class="display-2 mb-5 animated slideInDown">Đắm Chìm Trong Thế Giới Âm Thanh</h1>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill py-sm-3 px-sm-5">Sản Phẩm</a>
                                    <a asp-controller="Home" asp-action="Feature" class="btn btn-secondary rounded-pill py-sm-3 px-sm-5 ms-3">Dịch Vụ</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <img class="w-100" src="~/img/anh.jpg" alt="Image">
                    <div class="carousel-caption">
                        <div class="container">
                            <div class="row justify-content-start">
                                <div class="col-lg-7">
                                    <h1 class="display-2 mb-5 animated slideInDown">Âm Thanh Chuẩn – Phong Cách Chất</h1>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill py-sm-3 px-sm-5">Sản Phẩm</a>
                                    <a asp-controller="Home" asp-action="Feature" class="btn btn-secondary rounded-pill py-sm-3 px-sm-5 ms-3">Dịch Vụ</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#header-carousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Trước</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#header-carousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Kế tiếp</span>
            </button>
        </div>
    </div>
    <!-- Carousel End -->
    <!-- About Start -->
    <div class="container-xxl py-5">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                    <div class="about-img position-relative overflow-hidden p-5 pe-0">
                        <img class="img-fluid w-100" src="~/img/sound_2.jpg">
                    </div>
                </div>
                <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                    <h1 class="display-5 mb-4">Chạm Vào Sự Tĩnh Lặng, Thăng Hoa Cùng Âm Nhạc</h1>
                    <p class="mb-4">Dừng lại giữa thế giới ồn ào và đắm mình vào không gian âm thanh tách biệt hoàn toàn. Chiếc tai nghe chụp tai này không chỉ là thiết bị, mà là chìa khóa mở ra thế giới cảm xúc riêng biệt, nơi từng nốt nhạc được tái tạo tinh tế và nguyên bản nhất.</p>
                    <p><i class="fa fa-check text-primary me-3"></i>Thiết kế ôm trọn hoàn hảo, tạo cảm giác nhẹ tênh như không đeo.</p>
                    <p><i class="fa fa-check text-primary me-3"></i>Công nghệ triệt tiêu tiếng ồn chủ động, trả lại không gian tĩnh lặng tuyệt đối.</p>
                    <p><i class="fa fa-check text-primary me-3"></i>Âm thanh đa tầng sâu lắng, nâng tầm trải nghiệm nghe lên chuẩn phòng thu.</p>
                    <a asp-controller="Home" asp-action="About" class="btn btn-primary rounded-pill py-3 px-5 mt-3">XEM CHI TIẾT</a>
                </div>
            </div>
        </div>
    </div>
    <!-- About End -->
    <!-- Feature Start -->
    <div class="container-fluid bg-light bg-icon my-5 py-6">
        <div class="container">
            <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
                <h1 class="display-5 mb-3">Tinh Hoa Công Nghệ Âm Thanh</h1>
                <p>Khám phá sự hoàn mỹ trong từng giai điệu với thiết kế đỉnh cao, chất âm nguyên bản và công nghệ chống ồn đột phá.</p>
            </div>
            <div class="row g-4">
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="bg-white text-center h-100 p-4 p-xl-5">
                        <img class="img-fluid mb-4" src="~/img/sound_3.jpg" alt="">
                        <h4 class="mb-3">Âm Thanh Hi-Fi Sống Động</h4>
                        <p class="mb-4">Thưởng thức chất âm chi tiết với âm bass mạnh mẽ, âm trung rõ nét và âm cao trong trẻo, mang đến trải nghiệm nghe nhạc chân thực.</p>
                        <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="bg-white text-center h-100 p-4 p-xl-5">
                        <img class="img-fluid mb-4" src="~/img/sound_4.jpg" alt="">
                        <h4 class="mb-3">Chống Ồn Hiệu Quả</h4>
                        <p class="mb-4">Khả năng chống ồn chủ động (ANC) đỉnh cao biến mọi không gian ồn ào trở thành sân khấu riêng, nơi chỉ còn bạn và những giai điệu yêu thích.</p>
                        <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                    <div class="bg-white text-center h-100 p-4 p-xl-5">
                        <img class="img-fluid mb-4" src="~/img/sound_8.jpg" alt="">
                        <h4 class="mb-3">Thiết Kế Sang Trọng</h4>
                        <p class="mb-4">Khung tai nghe chắc chắn, đệm tai cao cấp và trọng lượng nhẹ, phù hợp cho học tập, làm việc và giải trí hàng ngày.</p>
                        <a asp-controller="Home" asp-action="Feature" class="btn btn-outline-primary border-2 py-2 px-4 rounded-pill">Đọc Thêm</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Feature End -->
    <!-- Product Start (dữ liệu lấy từ SQL Server) -->
    <div class="container-xxl py-5">
        <div class="container">
            <div class="row g-0 gx-5 align-items-end">
                <div class="col-lg-6">
                    <div class="section-header text-start mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
                        <h1 class="display-5 mb-3">Khám Phá Tai Nghe Chụp Tai.</h1>
                        <p>Lựa chọn những mẫu tai nghe chất lượng cao với âm thanh sắc nét, thiết kế êm ái và công nghệ Bluetooth hiện đại. Phù hợp cho học tập, làm việc, giải trí và gaming.</p>
                    </div>
                </div>
                <div class="col-lg-6 text-start text-lg-end wow slideInRight" data-wow-delay="0.1s">
                    <div class="dropdown d-inline-block mb-5">
                        <button class="btn btn-outline-primary dropdown-toggle"
                                type="button"
                                id="categoryDropdown"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Phân loại
                        </button>

                        <ul class="dropdown-menu" id="categoryFilters">
                            <li><a class="dropdown-item active" href="#" data-category="all">Tất cả</a></li>
                            <li><a class="dropdown-item" href="#" data-category="Tai nghe chụp tai có dây">Tai nghe chụp tai có dây</a></li>
                            <li><a class="dropdown-item" href="#" data-category="Tai nghe chụp tai không dây">Tai nghe chụp tai không dây</a></li>
                            <li><a class="dropdown-item" href="#" data-category="Tai nghe nhét tai">Tai nghe nhét tai</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="tab-content">
                <div id="tab-1" class="tab-pane fade show p-0 active">
                    <div class="row g-4" id="productList">
                        @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                        <div class="col-xl-3 col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s" data-category="@product.Category?.CategoryName">
                            <div class="product-item">
                                <div class="position-relative bg-light overflow-hidden">
                                    <img class="img-fluid w-100" src="~/img/@product.ImagePath" alt="@product.ProductName">
                                    @if (product.IsNew)
                                        {
                                    <div class="bg-secondary rounded text-white position-absolute start-0 top-0 m-4 py-1 px-3">New</div>
                                        }
                                </div>
                                <div class="text-center p-4">
                                    <a class="d-block h5 mb-2" asp-controller="Product" asp-action="Details" asp-route-id="@product.ProductId">@product.ProductName</a>
                                    <span class="text-primary me-1">@product.Price.ToString("N0", vi)</span>
                                    @if (product.OldPrice.HasValue)
                                        {
                                    <span class="text-body text-decoration-line-through">@product.OldPrice.Value.ToString("N0", vi)</span>
                                        }
                                </div>
                                <div class="d-flex border-top">
                                    <small class="w-50 text-center border-end py-2">
                                        <a class="text-body" asp-controller="Product" asp-action="Details" asp-route-id="@product.ProductId"><i class="fa fa-eye text-primary me-2"></i>Xem chi tiết</a>
                                    </small>
                                    <small class="w-50 text-center py-2">
                                        <a class="text-body" href="javascript:void(0)"><i class="fa fa-shopping-bag text-primary me-2"></i>Thêm vào giỏ hàng</a>
                                    </small>
                                </div>
                            </div>
                        </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center p-5">
                            <h5 class="text-muted">Chưa có sản phẩm nào.</h5>
                        </div>
                    }
                        <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.1s">
                            <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill py-3 px-5">Xem thêm sản phẩm</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Product End -->
    <!-- Firm Visit Start -->
    <div class="container-fluid bg-primary bg-icon mt-5 py-6">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-md-7 wow fadeIn" data-wow-delay="0.1s">
                    <h1 class="display-5 text-white mb-3">Kiến tạo không gian âm thanh tuyệt đối</h1>
                    <p class="text-white mb-0">Đánh thức mọi giác quan với sự kết hợp hoàn hảo giữa công nghệ âm thanh vòm đỉnh cao và thiết kế công thái học ôm trọn cảm xúc. Hãy để bản thân thăng hoa trong từng nốt nhạc, trải nghiệm chất âm chân thực đến từng nhịp thở!</p>
                </div>
                <div class="col-md-5 text-md-end wow fadeIn" data-wow-delay="0.5s">
                    <a asp-controller="Home" asp-action="About" class="btn btn-lg btn-secondary rounded-pill py-3 px-5">Truy cập ngay</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Firm Visit End -->
    <!-- Testimonial Start -->
    <div class="container-fluid bg-light bg-icon py-6 mb-5">
        <div class="container">
            <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
                <h1 class="display-5 mb-3">Khách Hàng Nói Gì Về Chúng Tôi</h1>
                <p>Mỗi phản hồi là nguồn động lực để chúng tôi không ngừng nâng cao chất lượng sản phẩm và dịch vụ. Cảm ơn quý khách đã tin tưởng lựa chọn những mẫu tai nghe chụp tai của chúng tôi!</p>
            </div>
            <div class="owl-carousel testimonial-carousel wow fadeInUp" data-wow-delay="0.1s">
                <div class="testimonial-item position-relative bg-white p-5 mt-4">
                    <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                    <p class="mb-4">Chất lượng âm thanh rất ấn tượng, bass mạnh nhưng vẫn giữ được độ chi tiết. Đeo liên tục nhiều giờ vẫn rất thoải mái nhờ phần đệm tai mềm. Rất đáng tiền và sẽ tiếp tục ủng hộ.</p>
                    <div class="d-flex align-items-center">
                        <img class="flex-shrink-0 rounded-circle" src="~/img/anh 1.jpg" alt="">
                        <div class="ms-3">
                            <h5 class="mb-1">Lưu Học Nghĩa</h5>
                            <span>Diễn viên</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-item position-relative bg-white p-5 mt-4">
                    <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                    <p class="mb-4">Lần đầu mua tai nghe tại đây và thực sự vượt mong đợi. Kết nối Bluetooth nhanh, chống ồn hoạt động hiệu quả, pin dùng được nhiều ngày. Sản phẩm đúng như mô tả và giao hàng rất cẩn thận.</p>
                    <div class="d-flex align-items-center">
                        <img class="flex-shrink-0 rounded-circle" src="~/img/anh 2.jpg" alt="">
                        <div class="ms-3">
                            <h5 class="mb-1">Tiêu Chiến</h5>
                            <span>Diễn viên / Ca sĩ</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-item position-relative bg-white p-5 mt-4">
                    <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                    <p class="mb-4">Tai nghe có thiết kế đẹp, ôm tai vừa vặn và chất âm rõ ràng khi nghe nhạc lẫn gọi điện. Đóng gói chắc chắn, giao hàng nhanh và nhân viên tư vấn rất nhiệt tình. Mình rất hài lòng với trải nghiệm mua sắm.</p>
                    <div class="d-flex align-items-center">
                        <img class="flex-shrink-0 rounded-circle" src="~/img/anh 3.jpg" alt="">
                        <div class="ms-3">
                            <h5 class="mb-1">Vương Nhất Bác</h5>
                            <span>Ca sĩ / MC</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-item position-relative bg-white p-5 mt-4">
                    <i class="fa fa-quote-left fa-3x text-primary position-absolute top-0 start-0 mt-n4 ms-5"></i>
                    <p class="mb-4">Âm thanh trong game rất rõ, dễ xác định hướng bước chân và tiếng súng. Micro thu âm tốt, đồng đội nghe rất rõ. Một chiếc tai nghe rất đáng mua.</p>
                    <div class="d-flex align-items-center">
                        <img class="flex-shrink-0 rounded-circle" src="~/img/anh 4.jpg" alt="">
                        <div class="ms-3">
                            <h5 class="mb-1">Thành Nghị</h5>
                            <span>Diễn viên</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Testimonial End -->
    <!-- Blog Start (dữ liệu lấy từ SQL Server) -->
    <div class="container-xxl py-5">
        <div class="container">
            <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
                <h1 class="display-5 mb-3">Tin Tức Mới Nhất</h1>
                <p>Khám phá bộ sưu tập tai nghe chụp tai mới nhất – Đắm mình vào không gian riêng, nơi chỉ có bạn và âm nhạc.</p>
            </div>
            <div class="row g-4">
                @if (latestBlogs != null && latestBlogs.Any())
            {
                foreach (var blog in latestBlogs)
                {
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <img class="img-fluid" src="~/img/@blog.ImagePath" alt="@blog.Title">
                    <div class="bg-light p-4">
                        <a class="d-block h5 lh-base mb-4" asp-controller="Blog" asp-action="Details" asp-route-id="@blog.BlogId">@blog.Title</a>
                        <div class="text-muted border-top pt-4">
                            <small class="me-3"><i class="fa fa-user text-primary me-2"></i>Admin</small>
                            <small class="me-3"><i class="fa fa-calendar text-primary me-2"></i>@blog.CreatedDate.ToString("dd/MM/yyyy")</small>
                        </div>
                    </div>
                </div>
                }
            }
            else
            {
                <div class="col-12 text-center p-5">
                    <h5 class="text-muted">Hiện chưa có tin tức nào.</h5>
                </div>
            }
            </div>
        </div>
    </div>
    <!-- Blog End -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const items = document.querySelectorAll("#productList > div");
            const filters = document.querySelectorAll("#categoryFilters .dropdown-item");
            const dropdownButton = document.getElementById("categoryDropdown");

            filters.forEach(item => {

                item.addEventListener("click", function (e) {

                    e.preventDefault();

                    // bỏ active cũ
                    filters.forEach(x => x.classList.remove("active"));

                    // active mới
                    this.classList.add("active");

                    // đổi tên nút
                    dropdownButton.innerText = this.innerText;

                    let category = this.dataset.category;

                    items.forEach(product => {

                        if (category === "all") {

                            product.style.display = "";

                        } else {

                            if (product.dataset.category === category)
                                product.style.display = "";
                            else
                                product.style.display = "none";

                        }

                    });

                });

            });

        });
    </script>
