@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Đăng Nhập</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">Đăng nhập</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container-xxl py-6">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="bg-light shadow-sm p-5">
                    <h3 class="text-center mb-4">Đăng nhập tài khoản</h3>

                    @if (TempData["RegisterSuccess"] != null)
                    {
                        <div class="alert alert-success">@TempData["RegisterSuccess"]</div>
                    }

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <form asp-controller="Account" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div class="form-floating mb-3">
                            <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" autofocus>
                            <label asp-for="Username">Tên đăng nhập</label>
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control" placeholder="Mật khẩu">
                            <label asp-for="Password">Mật khẩu</label>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-3">ĐĂNG NHẬP</button>
                    </form>

                    <p class="text-center small mt-4 mb-0">
                        Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a>
                    </p>
                    <p class="text-center small text-muted mt-2">
                        (Tài khoản demo: <strong>admin/admin123</strong> hoặc <strong>customer/123456</strong>)
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
