@model List<CartItem>
    @{
    ViewData["Title"] = "Giỏ hàng";
    var vi = new System.Globalization.CultureInfo("vi-VN");
    }

               <div class="container-xxl py-5 mt-5 pt-5">
                   <div class="container">
                       <h1 class="mb-4">Giỏ hàng của bạn</h1>

                       @if (Model == null || !Model.Any())
        {
                       <p>Giỏ hàng đang trống.</p>
                       <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
        }
        else
        {
                       <table class="table align-middle">
                           <thead>
                               <tr>
                                   <th>Sản phẩm</th>
                                   <th>Đơn giá</th>
                                   <th>Số lượng</th>
                                   <th>Thành tiền</th>
                                   <th></th>
                               </tr>
                           </thead>
                           <tbody>
                               @foreach (var item in Model)
                    {
                               <tr>
                                   <td class="d-flex align-items-center">
                                       <img src="~/img/@item.ImagePath" width="60" class="me-3" />
                                       @item.ProductName
                                   </td>
                                   <td>@item.Price.ToString("N0", vi) đ</td>
                                   <td style="width:120px">
                                       <form asp-action="UpdateQuantity" method="post" class="d-flex">
                                           <input type="hidden" name="productId" value="@item.ProductId" />
                                           <input type="number" name="quantity" value="@item.Quantity" min="1"
                                                  class="form-control form-control-sm" style="width:70px" />
                                           <button type="submit" class="btn btn-sm btn-outline-primary ms-1">
                                               <i class="fa fa-sync"></i>
                                           </button>
                                       </form>
                                   </td>
                                   <td>@item.Total.ToString("N0", vi) đ</td>
                                   <td>
                                       <form asp-action="Remove" method="post">
                                           <input type="hidden" name="productId" value="@item.ProductId" />
                                           <button type="submit" class="btn btn-sm btn-outline-danger">
                                               <i class="fa fa-trash"></i>
                                           </button>
                                       </form>
                                   </td>
                               </tr>
                    }
                           </tbody>
                       </table>

                       <div class="text-end">
                           <h5>Tổng cộng: @Model.Sum(c => c.Total).ToString("N0", vi) đ</h5>
                           <a asp-action="Clear" onclick="return confirm('Xoá toàn bộ giỏ hàng?')" class="btn btn-outline-secondary">Xoá giỏ hàng</a>
                           <a href="#" class="btn btn-primary">Thanh toán</a>
                       </div>
        }
                   </div>
               </div>
