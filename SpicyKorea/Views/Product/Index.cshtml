@model IEnumerable<Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var vi = new System.Globalization.CultureInfo("vi-VN");
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Sản Phẩm</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">Sản phẩm</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->
<!-- Product Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-0 gx-5 align-items-end">
            <div class="col-lg-6">
                <div class="section-header text-start mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
                    <h1 class="display-5 mb-3">Thực Đơn Mì Cay.</h1>
                    <p>Khám phá tinh túy ẩm thực với sợi mì dai ngon hòa quyện cùng nước dùng đậm đà 7 cấp độ. Nguyên liệu tươi sạch, hương vị khó quên.</p>
                </div>
            </div>
            <div class="col-lg-6 text-start text-lg-end wow slideInRight" data-wow-delay="0.1s">
                <ul class="nav nav-pills d-inline-flex justify-content-end mb-5" id="categoryFilters">
                    <li class="nav-item me-2">
                        <a class="btn btn-outline-primary border-2 active" data-category="all" href="javascript:void(0)">Tất cả</a>
                    </li>
                    <li class="nav-item me-2">
                        <a class="btn btn-outline-primary border-2" data-category="Mỳ Cay" href="javascript:void(0)">Mỳ Cay</a>
                    </li>
                    <li class="nav-item me-2">
                        <a class="btn btn-outline-primary border-2" data-category="Đồ Uống" href="javascript:void(0)">Đồ Uống </a>
                    </li>
                    <li class="nav-item me-0">
                        <a class="btn btn-outline-primary border-2" data-category="Best Seller" href="javascript:void(0)">Best Seller</a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="tab-content">
            <div id="tab-1" class="tab-pane fade show p-0 active">
                <div class="row g-4" id="productList">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            <div class="col-xl-3 col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s" data-category="@product.Category?.CategoryName">
                                <div class="product-item">
                                    <div class="position-relative bg-light overflow-hidden">
                                        <img class="img-fluid w-100" src="~/img/@product.ImagePath" alt="@product.ProductName">
                                        @if (product.IsNew)
                                        {
                                            <div class="bg-secondary rounded text-white position-absolute start-0 top-0 m-4 py-1 px-3">New</div>
                                        }
                                    </div>
                                    <div class="text-center p-4">
                                        <a class="d-block h5 mb-2" asp-action="Details" asp-route-id="@product.ProductId">@product.ProductName</a>
                                        <span class="text-primary me-1">@product.Price.ToString("N0", vi)</span>
                                        @if (product.OldPrice.HasValue)
                                        {
                                            <span class="text-body text-decoration-line-through">@product.OldPrice.Value.ToString("N0", vi)</span>
                                        }
                                    </div>
                                    <div class="d-flex border-top">
                                        <small class="w-50 text-center border-end py-2">
                                            <a class="text-body" asp-action="Details" asp-route-id="@product.ProductId"><i class="fa fa-eye text-primary me-2"></i>Xem chi tiết</a>
                                        </small>
                                        <small class="w-50 text-center py-2">
                                            <a class="text-body" href="javascript:void(0)"><i class="fa fa-shopping-bag text-primary me-2"></i>Thêm vào giỏ hàng</a>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center p-5">
                            <h5 class="text-muted">Chưa có sản phẩm nào.</h5>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Product End -->
<!-- Firm Visit Start -->
<div class="container-fluid bg-primary bg-icon mt-5 py-6">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-md-7 wow fadeIn" data-wow-delay="0.1s">
                <h1 class="display-5 text-white mb-3">Khám phá hương vị</h1>
                <p class="text-white mb-0">Đánh thức mọi giác quan với sự kết hợp tinh tế giữa hải sản tươi và nước dùng 7 cấp độ cay nồng đặc trưng. Hãy đến và cùng chúng tôi khám phá hương vị mì cay đích thực, dai ngon đến sợi cuối cùng!</p>
            </div>
            <div class="col-md-5 text-md-end wow fadeIn" data-wow-delay="0.5s">
                <a asp-controller="Home" asp-action="About" class="btn btn-lg btn-secondary rounded-pill py-3 px-5">Truy cập ngay</a>
            </div>
        </div>
    </div>
</div>
<!-- Firm Visit End -->
