@{
    // ActivePage được set từ ViewData ở mỗi View để tô sáng menu đang chọn
    string active = ViewData["ActivePage"] as string ?? "";
    string username = Context.Session.GetString("Username");
    string role = Context.Session.GetString("Role");
}
<!-- Navbar Start -->
<div class="container-fluid fixed-top px-0 wow fadeIn" data-wow-delay="0.1s">
    <div class="top-bar row gx-0 align-items-center d-none d-lg-flex">
        <div class="col-lg-6 px-5 text-start">
            <small><i class="fa fa-map-marker-alt me-2"></i>TP.HCM, Việt Nam</small>
            <small class="ms-4"><i class="fa fa-envelope me-2"></i>spicykorea@gmail.com</small>
        </div>
        <div class="col-lg-6 px-5 text-end">
            <small>Theo dõi chúng tôi:</small>
            <a class="text-body ms-3" href=""><i class="fab fa-facebook-f"></i></a>
            <a class="text-body ms-3" href=""><i class="fab fa-twitter"></i></a>
            <a class="text-body ms-3" href=""><i class="fab fa-linkedin-in"></i></a>
            <a class="text-body ms-3" href=""><i class="fab fa-instagram"></i></a>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-light py-lg-0 px-lg-5 wow fadeIn" data-wow-delay="0.1s">
        <a asp-controller="Home" asp-action="Index" class="navbar-brand ms-4 ms-lg-0">
            <h1 class="fw-bold text-primary m-0">S<span class="text-secondary">picy</span> Korea</h1>
        </a>
        <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
            <div class="navbar-nav ms-auto p-4 p-lg-0">
                <a asp-controller="Home" asp-action="Index" class="nav-item nav-link @(active == "Home" ? "active" : "")">TRANG CHỦ</a>
                <a asp-controller="Home" asp-action="About" class="nav-item nav-link @(active == "About" ? "active" : "")">GIỚI THIỆU</a>
                <a asp-controller="Product" asp-action="Index" class="nav-item nav-link @(active == "Product" ? "active" : "")">SẢN PHẨM</a>
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle @(active is "Blog" or "Feature" or "Testimonial" ? "active" : "")" data-bs-toggle="dropdown">KHÁC</a>
                    <div class="dropdown-menu m-0">
                        <a asp-controller="Blog" asp-action="Index" class="dropdown-item @(active == "Blog" ? "active" : "")">TIN TỨC</a>
                        <a asp-controller="Home" asp-action="Feature" class="dropdown-item @(active == "Feature" ? "active" : "")">ƯU ĐIỂM</a>
                        <a asp-controller="Home" asp-action="Testimonial" class="dropdown-item @(active == "Testimonial" ? "active" : "")">ĐÁNH GIÁ</a>
                    </div>
                </div>
                <a asp-controller="Contact" asp-action="Index" class="nav-item nav-link @(active == "Contact" ? "active" : "")">LIÊN HỆ</a>
            </div>
            <div class="d-none d-lg-flex ms-2">
                <a class="btn-sm-square bg-white rounded-circle ms-3" href="">
                    <small class="fa fa-search text-body"></small>
                </a>
                @if (!string.IsNullOrEmpty(username))
                {
                    <div class="nav-item dropdown">
                        <a class="btn-sm-square bg-white rounded-circle ms-3 dropdown-toggle" href="#" data-bs-toggle="dropdown" title="@username">
                            <small class="fa fa-user text-body"></small>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end m-0">
                            <span class="dropdown-item-text">Xin chào, <strong>@username</strong></span>
                            @if (role == "Admin")
                            {
                                <a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Trang quản trị</a>
                            }
                            <a class="dropdown-item" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                        </div>
                    </div>
                }
                else
                {
                    <a class="btn-sm-square bg-white rounded-circle ms-3" asp-controller="Account" asp-action="Login" id="userBtn">
                        <small class="fa fa-user text-body"></small>
                    </a>
                }
                <a class="btn-sm-square bg-white rounded-circle ms-3 position-relative" asp-controller="Product" asp-action="Index" id="cartBtn">
                    <small class="fa fa-shopping-bag text-body"></small>
                    <span id="cartCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
                </a>
            </div>
        </div>
    </nav>
</div>
<!-- Navbar End -->
