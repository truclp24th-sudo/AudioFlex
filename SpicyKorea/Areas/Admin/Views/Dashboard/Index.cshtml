@model IEnumerable<Order>
@{
    var vi = new System.Globalization.CultureInfo("vi-VN");
}

<div class="row">
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box text-bg-primary">
            <div class="inner">
                <h3>@ViewBag.TotalProducts</h3>
                <p>Sản phẩm</p>
            </div>
            <i class="small-box-icon bi bi-box-seam-fill"></i>
            <a asp-controller="Products" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box text-bg-secondary">
            <div class="inner">
                <h3>@ViewBag.TotalCategories</h3>
                <p>Danh mục</p>
            </div>
            <i class="small-box-icon bi bi-tags-fill"></i>
            <a asp-controller="Categories" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box text-bg-success">
            <div class="inner">
                <h3>@ViewBag.TotalBlogs</h3>
                <p>Tin tức</p>
            </div>
            <i class="small-box-icon bi bi-newspaper"></i>
            <a asp-controller="Blogs" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box text-bg-warning">
            <div class="inner">
                <h3>@ViewBag.TotalOrders</h3>
                <p>Đơn hàng</p>
            </div>
            <i class="small-box-icon bi bi-cart-check-fill"></i>
            <a asp-controller="Orders" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box text-bg-info">
            <div class="inner">
                <h3>@ViewBag.TotalAccounts</h3>
                <p>Tài khoản</p>
            </div>
            <i class="small-box-icon bi bi-people-fill"></i>
            <a asp-controller="Users" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-6">
        <div class="small-box text-bg-danger">
            <div class="inner">
                <h3>@ViewBag.TotalContacts</h3>
                <p>Phản hồi</p>
            </div>
            <i class="small-box-icon bi bi-chat-left-text-fill"></i>
            <a asp-controller="Feedbacks" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
        </div>
    </div>
</div>

<div class="card mt-2">
    <div class="card-header">
        <h3 class="card-title">Đơn hàng gần đây</h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>@order.CustomerName</td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.TotalAmount.ToString("N0", vi) đ</td>
                            <td><span class="badge text-bg-info">@order.Status</span></td>
                            <td><a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">Xem</a></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Chưa có đơn hàng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
