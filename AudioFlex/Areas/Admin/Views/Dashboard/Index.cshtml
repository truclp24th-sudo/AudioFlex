@model IEnumerable<Order>
    @{
    var vi = new System.Globalization.CultureInfo("vi-VN");
    }

    <!-- Giữ nguyên 6 ô thống kê nhanh -->
    <div class="row">
        <div class="col-lg-2 col-md-4 col-6">
            <div class="small-box text-bg-primary">
                <div class="inner">
                    <h3>@ViewBag.TotalProducts</h3>
                    <p>Sản phẩm</p>
                </div>
                <i class="small-box-icon bi bi-box-seam-fill"></i>
                <a asp-controller="Products" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="small-box text-bg-secondary">
                <div class="inner">
                    <h3>@ViewBag.TotalCategories</h3>
                    <p>Danh mục</p>
                </div>
                <i class="small-box-icon bi bi-tags-fill"></i>
                <a asp-controller="Categories" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="small-box text-bg-success">
                <div class="inner">
                    <h3>@ViewBag.TotalBlogs</h3>
                    <p>Tin tức</p>
                </div>
                <i class="small-box-icon bi bi-newspaper"></i>
                <a asp-controller="Blogs" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="small-box text-bg-warning">
                <div class="inner">
                    <h3>@ViewBag.TotalOrders</h3>
                    <p>Đơn hàng</p>
                </div>
                <i class="small-box-icon bi bi-cart-check-fill"></i>
                <a asp-controller="Orders" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="small-box text-bg-info">
                <div class="inner">
                    <h3>@ViewBag.TotalAccounts</h3>
                    <p>Tài khoản</p>
                </div>
                <i class="small-box-icon bi bi-people-fill"></i>
                <a asp-controller="Users" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="small-box text-bg-danger">
                <div class="inner">
                    <h3>@ViewBag.TotalContacts</h3>
                    <p>Phản hồi</p>
                </div>
                <i class="small-box-icon bi bi-chat-left-text-fill"></i>
                <a asp-controller="Feedbacks" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-link-45deg"></i></a>
            </div>
        </div>
    </div>

    <!-- Giữ nguyên bảng đơn hàng gần đây -->
    <div class="card mt-2">
        <div class="card-header">
            <h3 class="card-title">Đơn hàng gần đây</h3>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                {
                    // 1. Khai báo biến đếm bắt đầu từ 1
                    int stt = 1;

                    foreach (var order in Model)
                    {
                    <tr>
                        <!-- 2. Thay @order.OrderId bằng biến stt -->
                        <td>@(stt++)</td>
                        <td>@order.CustomerName</td>
                        <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@order.TotalAmount.ToString("N0", vi) đ</td>
                        <td><span class="badge text-bg-info">@order.Status</span></td>
                        <td>
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">Xem</a>
                        </td>
                    </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Chưa có đơn hàng nào.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ======================================================= -->
    <!-- PHẦN THÊM MỚI: BIỂU ĐỒ VÀ THỐNG KÊ DOANH THU THEO THÁNG -->
    <!-- ======================================================= -->
    <div class="row mt-4">
        <!-- Cột bên trái: Biểu đồ đường -->
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title text-primary fw-bold">Biểu đồ doanh thu 12 tháng gần nhất</h3>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" style="min-height: 300px; height: 300px; max-height: 300px; width: 100%;"></canvas>
                </div>
            </div>
        </div>

        <!-- Cột bên phải: Bảng thống kê con số chi tiết -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title text-primary fw-bold">Doanh số chi tiết</h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Tháng/Năm</th>
                                    <th class="text-end pe-3">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.MonthlyRevenue != null)
                            {
                                foreach (var item in ViewBag.MonthlyRevenue)
                                {
                                <tr>
                                    <td class="ps-3">Tháng @item.Month/@item.Year</td>
                                    <td class="text-end pe-3 fw-bold text-success">@item.Revenue.ToString("N0", vi) đ</td>
                                </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-center py-3">Chưa có dữ liệu thống kê.</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <!-- Thư viện Chart.js -->
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Nhận dữ liệu từ ViewBag
            var monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthlyRevenue));

            if (monthlyData && monthlyData.length > 0) {
                // 2. Đảo ngược mảng để vẽ từ cũ đến mới
                var sortedData = monthlyData.slice().reverse();

                var labels = sortedData.map(x => "T" + x.Month + "/" + x.Year);
                var values = sortedData.map(x => x.Revenue);

                // 3. Cấu hình và vẽ biểu đồ
                var ctx = document.getElementById('revenueChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Doanh thu',
                            data: values,
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 5,
                            pointBackgroundColor: '#0d6efd'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return value.toLocaleString('vi-VN') + ' đ';
                                    }
                                }
                            }
                        },
                        plugins: {
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return 'Doanh thu: ' + context.raw.toLocaleString('vi-VN') + ' đ';
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
        </script>
    }
