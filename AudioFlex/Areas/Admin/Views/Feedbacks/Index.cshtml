@model IEnumerable<Contact>

    <div class="card mb-4">
        <div class="card-header">
            <h3 class="card-title">Danh sách phản hồi liên hệ</h3>
        </div>
        <div class="card-body">
            
                <table class="table table-bordered table-striped align-middle">
                    <thead>
                        <tr>
                            <th style="width:60px">#</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            @* ĐÃ BỎ CỘT TIÊU ĐỀ *@
                            <th>Nội dung</th>
                            <th>Phản hồi khách hàng</th> @* CỘT MỚI *@
                            <th>Thời gian</th>
                            <th style="width:80px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
        {
            int stt = 1;
            foreach (var contact in Model)
            {
                        <tr>
                            <td>@(stt++)</td>
                            <td>@contact.Name</td>
                            <td>@contact.Email</td>
                            <td style="max-width:250px;white-space:normal;">@contact.Message</td>

                            @* CỘT NHẬP PHẢN HỒI *@
                            <td>
                                <form asp-action="UpdateReply" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="id" value="@contact.ContactId" />
                                    <textarea name="reply" class="form-control form-control-sm" rows="2" placeholder="Nhập câu trả lời...">@contact.AdminReply</textarea>
                                    <button type="submit" class="btn btn-sm btn-primary">Gửi</button>
                                </form>
                            </td>

                            <td>@contact.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@contact.ContactId" method="post" onsubmit="return confirm('Xóa phản hồi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
            }
        }
                    </tbody>
                </table>
        </div>
    </div>
