@using AudioFlex.Models
@using AudioFlex.Extensions
@model Order
@{
    ViewData["Title"] = "Thanh toán";
    var vi = new System.Globalization.CultureInfo("vi-VN");
    // Lấy giỏ hàng từ Session ngay tại đây
    var cart = Context.Session.GetObject<List<CartItem>>("Cart");
}

<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center">
        <h1 class="display-3 mb-3 animated slideInDown">Thanh Toán</h1>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-7">
                <h4 class="mb-4 text-primary">Thông tin giao hàng</h4>
                <form asp-action="Checkout" method="post" class="p-4 border rounded shadow-sm bg-light">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên người nhận</label>
                        <input asp-for="CustomerName" class="form-control" placeholder="Nhập tên người nhận hàng" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại liên hệ" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Số nhà, tên đường..." required></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ghi chú đơn hàng</label>
                        <textarea asp-for="Note" class="form-control" rows="2" placeholder="Lưu ý cho shipper..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">XÁC NHẬN ĐẶT HÀNG</button>
                </form>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white text-center">
                        <h4 class="mb-0 text-white">Tóm tắt đơn hàng</h4>
                    </div>
                    <div class="card-body">
                        @if (cart != null && cart.Any())
                        {
                        @* LỖI NẰM Ở ĐÂY NẾU THIẾU DẤU @ TRƯỚC FOREACH *@
                        @foreach (var item in cart)
                            {
                        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                            <span>
                                <strong>@item.ProductName</strong> <br />
                                <small class="text-muted">Số lượng: @item.Quantity</small>
                            </span>
                            <span class="fw-bold">@item.Total.ToString("N0", vi) đ</span>
                        </div>
                            }

                        <div class="d-flex justify-content-between h4 text-danger fw-bold mt-3">
                            <span>TỔNG CỘNG:</span>
                            <span>@cart.Sum(c => c.Total).ToString("N0", vi) đ</span>
                        </div>
                        }
                        else
                        {
                        <div class="text-center py-4">
                            <p class="mb-3 text-muted">Giỏ hàng của bạn đang trống</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-primary">Đi mua hàng ngay</a>
                        </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>