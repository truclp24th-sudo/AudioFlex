@model Product
@{
    ViewData["Title"] = Model.ProductName;
    var vi = new System.Globalization.CultureInfo("vi-VN");
    var related = ViewBag.RelatedProducts as IEnumerable<Product>;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Chi Tiết Sản Phẩm</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a class="text-body" asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <!-- CỘT TRÁI: HIỂN THỊ ẢNH (Ảnh lớn và hàng ảnh nhỏ) -->
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="product-gallery">
                    <!-- Ảnh chính hiện tại -->
                    <div class="main-image border rounded overflow-hidden bg-light mb-3">
                        <img id="mainProductImage" class="img-fluid w-100" src="~/img/@Model.ImagePath"
                             alt="@Model.ProductName" style="object-fit: contain; height: 450px;">
                    </div>

                    <!-- Hàng ảnh nhỏ (Thumbnails) -->
                    <div class="d-flex flex-wrap gap-2 justify-content-start">
                        @* Ảnh mặc định đầu tiên *@
                        <div class="thumb-item border rounded active-thumb" onclick="changeImage(this, '@Url.Content("~/img/" + Model.ImagePath)')">
                            <img src="~/img/@Model.ImagePath" style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;">
                        </div>

                        @* Các ảnh màu sắc khác từ bảng ProductImages *@
                        @if (Model.ProductImages != null && Model.ProductImages.Any())
                        {
                            foreach (var img in Model.ProductImages)
                            {
                        <div class="thumb-item border rounded" onclick="changeImage(this, '@Url.Content("~/img/" + img.ImagePath)')">
                            <img src="~/img/@img.ImagePath" title="@img.ColorName"
                                 style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;">
                        </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI: THÔNG TIN CHI TIẾT -->
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.3s">
                <span class="badge bg-secondary mb-3">@Model.Category?.CategoryName</span>
                <h1 class="display-6 mb-3">@Model.ProductName</h1>
                <div class="mb-4">
                    <span class="text-primary h4 me-2">@Model.Price.ToString("N0", vi) đ</span>
                    @if (Model.OldPrice.HasValue)
                    {
                    <span class="text-body text-decoration-line-through">@Model.OldPrice.Value.ToString("N0", vi) đ</span>
                    }
                </div>
                <p class="mb-4">@Model.Description</p>
                <a href="javascript:void(0)"
                   id="btnAddToCart"
                   class="btn btn-primary rounded-pill py-3 px-5"
                   data-id="@Model.ProductId"
                   data-image="@Model.ImagePath">
                    <i class="fa fa-shopping-bag me-2"></i>Thêm vào giỏ hàng
                </a>
                <a asp-action="Index" class="btn btn-outline-primary rounded-pill py-3 px-5 ms-2">Quay lại danh sách</a>
            </div>
        </div>

        @* --- Sản phẩm cùng danh mục --- *@
        @if (related != null && related.Any())
        {
        <div class="section-header text-start mt-6 mb-4">
            <h3>Sản phẩm cùng danh mục</h3>
        </div>
        <div class="row g-4">
            @foreach (var p in related)
                {
            <div class="col-xl-3 col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="product-item">
                    <div class="position-relative bg-light overflow-hidden">
                        <img class="img-fluid w-100" src="~/img/@p.ImagePath" alt="@p.ProductName">
                    </div>
                    <div class="text-center p-4">
                        <a class="d-block h5 mb-2" asp-action="Details" asp-route-id="@p.ProductId">@p.ProductName</a>
                        <span class="text-primary me-1">@p.Price.ToString("N0", vi)</span>
                    </div>
                </div>
            </div>
                }
        </div>
        }
    </div>
</div>

@* --- CSS và SCRIPT để xử lý đổi ảnh --- *@
<style>
    .thumb-item {
        overflow: hidden;
        transition: 0.3s;
        border: 2px solid transparent !important;
    }

        .thumb-item:hover {
            opacity: 0.8;
        }

    .active-thumb {
        border: 2px solid #3cb815 !important; /* Màu xanh của website */
    }
</style>

<!-- 2. Cập nhật script changeImage -->
@section Scripts {
    <script>
        function changeImage(element, newSrc) {
            document.getElementById('mainProductImage').src = newSrc;
            var thumbs = document.querySelectorAll('.thumb-item');
            thumbs.forEach(t => t.classList.remove('active-thumb'));
            element.classList.add('active-thumb');

            // Cập nhật tên file ảnh vào data-image
            var fileName = newSrc.split('/').pop();
            document.getElementById('btnAddToCart').setAttribute('data-image', fileName);
        }

        $(document).ready(function () {
            // Dùng ID để bắt sự kiện chính xác, và tắt các sự kiện click khác nếu có
            $('#btnAddToCart').off('click').on('click', function (e) {
                e.preventDefault();
                e.stopImmediatePropagation(); // Chặn các script khác nhảy vào nút này

                var pId = $(this).data('id');
                var imgPath = $(this).attr('data-image');

                $.ajax({
                    url: '/Cart/Add',
                    type: 'POST',
                    data: {
                        productId: pId,
                        imagePath: imgPath,
                        quantity: 1
                    },
                    success: function (res) {
                        if (res.success) {
                            // Cập nhật số lượng trên icon giỏ hàng
                            $('#cartCount').text(res.cartCount);

                            // CHỈ ĐỂ DUY NHẤT 1 CÁI ALERT Ở ĐÂY
                            alert("Đã thêm vào giỏ hàng thành công!");
                        }
                    },
                    error: function () {
                        alert("Lỗi hệ thống, vui lòng thử lại!");
                    }
                });
            });
        });
    </script>
}